<Page
    x:Class="PacmanGameProject.Game.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="GameCanvas_KeyDown"
    Loaded="GameCanvas_Loaded"
    IsTabStop="True"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HUD -->
        <Grid Grid.Row="0" Margin="10,10,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TimeText"
                       Text="TIME: 00:00"
                       FontFamily="Consolas"
                       FontSize="20"
                       Foreground="Yellow"
                       HorizontalAlignment="Left"
                       Grid.Column="0"/>

            <TextBlock x:Name="ScoreText"
                       Text="SCORE: 0"
                       FontFamily="Consolas"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Grid.Column="1"/>

            <TextBlock x:Name="LivesText"
                       Text="LIVES: 3"
                       FontFamily="Consolas"
                       FontSize="20"
                       Foreground="Red"
                       HorizontalAlignment="Right"
                       Grid.Column="2"/>
        </Grid>

        <!-- GAME AREA -->
        <Viewbox Grid.Row="1" Stretch="Uniform">
            <Grid Width="224" Height="248">

                <!-- MAPA -->
                <Canvas x:Name="MapCanvas"
                        Background="Black"/>

                <!-- SPRITES -->
                <Canvas x:Name="SpriteCanvas"
                        Background="Transparent"
                        IsTabStop="True"
                        KeyDown="GameCanvas_KeyDown">

                    <!-- FANTASMAS -->
                    <Image x:Name="BlinkyImage"
                           Source="Assets/ghosts/vermelho/0.png"
                           Width="12"
                           Height="12"/>

                    <Image x:Name="PinkyImage"
                           Source="Assets/ghosts/rosa/0.png"
                           Width="12"
                           Height="12"/>

                    <Image x:Name="InkyImage"
                           Source="Assets/ghosts/azul/0.png"
                           Width="12"
                           Height="12"/>

                    <Image x:Name="ClydeImage"
                           Source="Assets/ghosts/laranja/0.png"
                           Width="12"
                           Height="12"/>

                    <!-- PACMAN -->
                    <Image x:Name="PacmanImage"
                           Width="12"
                           Height="12"
                           RenderTransformOrigin="0.5,0.5"/>
                </Canvas>

                <!-- DEBUG -->
                <Canvas x:Name="DebugLayer"
                        Visibility="Collapsed"/>
            </Grid>
        </Viewbox>

        <!-- CONTROLES -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="2"
                    Margin="10">

            <Button Content="←"/>
            <Button Content="↑"/>
            <Button Content="↓"/>
            <Button Content="→"/>
        </StackPanel>

        <!-- GAME OVER -->
        <Grid x:Name="GameOverOverlay" Visibility="Collapsed" Background="#CC000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

                <TextBlock Text="GAME OVER"
                           FontSize="48"
                           Foreground="Red"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"/>

                <TextBlock x:Name="FinalScoreText"
                           Text="SCORE: 0"
                           FontSize="24"
                           Foreground="White"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"/>

                <Button Content="JOGAR DE NOVO"
                        Click="RestartGame_Click"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        Width="200"
                        Background="DarkBlue"
                        Foreground="White"/>

                <Button Content="VOLTAR PARA O MENU"
                        Click="BackToMenu_Click"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        Width="200"
                        Background="Gray"
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- WIN -->
        <Grid x:Name="VictoryOverlay" Background="#CC000000" Visibility="Collapsed" Canvas.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <TextBlock Text="YOU WIN!" 
                       Foreground="LimeGreen" FontSize="72" 
                       FontFamily="Segoe UI Black" HorizontalAlignment="Center"/>

                <TextBlock x:Name="VictoryScoreText" Text="SCORE: 0" 
                       Foreground="White" FontSize="36" 
                       FontFamily="Consolas" HorizontalAlignment="Center"/>

                <Button Content="CONTINUAR" 
                    Click="BackToMenu_Click"
                    Width="300" Height="50"
                    FontSize="20" Background="Blue" Foreground="White"
                    CornerRadius="10" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
