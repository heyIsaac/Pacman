<Page
    x:Class="PacmanGameProject.Game.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="GameCanvas_KeyDown"
    KeyUp="GameCanvas_KeyUp"
    Loaded="GameCanvas_Loaded"
    IsTabStop="True"
    Background="Black">

    <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Área do jogo -->
    <Canvas x:Name="GameCanvas" Background="Black" Grid.Row="0">

        <Image x:Name="MapImage"
               Source="Assets/map-default.png"
               Width="650"
               Height="576"
               Canvas.ZIndex="0"/>

        <!-- Pacman -->
        <Image Canvas.Top="180" Canvas.Left="151" x:Name="PacmanImage"
               Source="Assets/pacman/live/pacman_live_1.png"
               Width="32"
               Height="32"
               Canvas.ZIndex="1" />
    </Canvas>

    <!-- Controles -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Grid.Row="1"
                Margin="10">

        <Button Content="←"/>
        <Button Content="↑" />
        <Button Content="↓" />
        <Button Content="→" />
    </StackPanel>
    </Grid>
</Page>