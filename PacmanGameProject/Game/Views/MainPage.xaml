<Page
    x:Class="PacmanGameProject.Game.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="GameCanvas_KeyDown"
    Loaded="GameCanvas_Loaded"
    IsTabStop="True"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HUD -->
        <Grid Grid.Row="0" Margin="0,10,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="ScoreText"
                       Text="SCORE: 0"
                       FontFamily="Consolas"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Grid.Column="0"/>

            <TextBlock x:Name="TimeText"
                       Text="TIME: 00:00"
                       FontFamily="Consolas"
                       FontSize="28"
                       Foreground="Yellow"
                       HorizontalAlignment="Center"
                       Grid.Column="1"/>
        </Grid>

        <!-- GAME AREA -->
        <Viewbox Grid.Row="1" Stretch="Uniform">
            <Canvas x:Name="GameCanvas"
                    Background="Black"
                    Width="224"
                    Height="248"
                    IsTabStop="True"
                    KeyDown="GameCanvas_KeyDown">

                <!-- FANTASMAS -->
                <Image x:Name="BlinkyImage"
                       Source="Assets/ghosts/vermelho/0.png"
                       Width="12"
                       Height="12"
                       Canvas.ZIndex="2"/>

                <Image x:Name="PinkyImage"
                       Source="Assets/ghosts/rosa/0.png"
                       Width="12"
                       Height="12"
                       Canvas.ZIndex="2"/>

                <Image x:Name="InkyImage"
                       Source="Assets/ghosts/azul/0.png"
                       Width="12"
                       Height="12"
                       Canvas.ZIndex="2"/>

                <Image x:Name="ClydeImage"
                       Source="Assets/ghosts/laranja/0.png"
                       Width="12"
                       Height="12"
                       Canvas.ZIndex="2"/>

                <!-- PACMAN -->
                <Image x:Name="PacmanImage"
                       Width="12"
                       Height="12"
                       Canvas.ZIndex="3"
                       RenderTransformOrigin="0.5,0.5"/>

                <!-- DEBUG -->
                <Canvas x:Name="DebugLayer"
                        Canvas.ZIndex="10"
                        Visibility="Collapsed"/>
            </Canvas>
        </Viewbox>

        <!-- CONTROLES -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="2"
                    Margin="10">

            <Button Content="←"/>
            <Button Content="↑"/>
            <Button Content="↓"/>
            <Button Content="→"/>
        </StackPanel>
    </Grid>
</Page>
