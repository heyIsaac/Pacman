<Page
    x:Class="PacmanGameProject.Game.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="GameCanvas_KeyDown"
    KeyUp="GameCanvas_KeyUp"
    Loaded="GameCanvas_Loaded"
    IsTabStop="True"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0" Stretch="Uniform">

            <Canvas x:Name="GameCanvas" Background="Black" Width="896" Height="768">

                <Image Source="ms-appx:///Assets/map-default.png" 
                       Width="896" 
                       Height="768" 
                       Stretch="Uniform"
                       Canvas.Left="0" 
                       Canvas.Top="0"
                       Canvas.ZIndex="0"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <CompositeTransform TranslateX="-50" TranslateY="-7"/>
                    </Image.RenderTransform>
                </Image>

                <Image x:Name="BlinkyImage" Source="Assets/ghosts/vermelho/0.png" Width="24" Height="24" Canvas.ZIndex="2"/>
                <Image x:Name="PinkyImage" Source="Assets/ghosts/rosa/0.png" Width="24" Height="24" Canvas.ZIndex="2"/>
                <Image x:Name="InkyImage" Source="Assets/ghosts/azul/0.png" Width="24" Height="24" Canvas.ZIndex="2"/>
                <Image x:Name="ClydeImage" Source="Assets/ghosts/laranja/0.png" Width="24" Height="24" Canvas.ZIndex="2"/>

                <Image x:Name="PacmanImage"
                       Width="24" Height="24"
                       Canvas.ZIndex="3"
                       RenderTransformOrigin="0.5,0.5"/>

                <Canvas x:Name="DebugLayer" Canvas.ZIndex="10" Visibility="Collapsed"/>
            </Canvas>

        </Viewbox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="1"
                    Margin="10">

            <Button Content="←"/>
            <Button Content="↑" />
            <Button Content="↓" />
            <Button Content="→" />
        </StackPanel>
    </Grid>
</Page>
