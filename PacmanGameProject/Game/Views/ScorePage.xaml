<Page
    x:Class="PacmanGameProject.Game.Views.ScorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="HIGHSCORES" 
                   Foreground="White" FontSize="36" 
                   HorizontalAlignment="Center" Margin="20"/>

        <ListView x:Name="ScoreList" Grid.Row="1" HorizontalAlignment="Center">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="300">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" Foreground="Yellow" FontSize="20"/>
                        <TextBlock Text="{Binding Points}" Foreground="White" FontSize="20" Grid.Column="1"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="2" Content="Voltar ao Menu" Click="OnBackClicked"
                HorizontalAlignment="Center" Margin="20" Background="Gray" Foreground="White"/>
    </Grid>
</Page>
